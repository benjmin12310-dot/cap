# ── App ──────────────────────────────────────────────
APP_NAME=Dental Clinic Management System
APP_DEBUG=false
BASE_URL=http://localhost/cap/

# ── Database ──────────────────────────────────────────
DB_HOST=localhost
DB_NAME=cap_db
DB_USER=root
DB_PASS=

# ── PayMongo ──────────────────────────────────────────
# Get these from: https://dashboard.paymongo.com/developers
#
# Secret Key (starts with sk_live_ for live, sk_test_ for test mode)
PAYMONGO_SECRET_KEY=sk_live_REPLACE_WITH_YOUR_KEY_HERE

# Webhook Secret (get this after creating a webhook in PayMongo dashboard)
# Set webhook URL to: https://yourdomain.com/cap/api/paymongo_webhook.php
# Subscribe to events: payment.paid, link.payment.paid
PAYMONGO_WEBHOOK_SECRET=whsec_REPLACE_AFTER_CREATING_WEBHOOK
